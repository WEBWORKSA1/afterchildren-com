# Environment variables for AfterChildren.com
# Copy this file to .env (which is gitignored) and fill in real values for local dev.
# For production, set these in the Vercel dashboard under Settings → Environment Variables.

# ---- Beehiiv newsletter integration ----
# Get these from your Beehiiv account:
#   1. https://app.beehiiv.com/settings/integrations/api
#   2. Click "Create New API Key" → name it "afterchildren-vercel" → copy the key
#   3. Publication ID is in the URL when you're inside your publication:
#      https://app.beehiiv.com/p/PUBLICATION_ID/dashboard
# The publication ID starts with "pub_" followed by a UUID.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ---- Optional public vars (safe to expose to the browser) ----
# Currently unused — kept for forward-compatibility if we add Plausible/PostHog etc.
# PUBLIC_ANALYTICS_DOMAIN=afterchildren.com
