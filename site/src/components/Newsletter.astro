---
// Newsletter placeholder block.
//
// The Sunday Letter is not active yet. Capture infrastructure (Beehiiv, Kit, etc.)
// is deferred until the site has ~1,000 readers — the point at which a newsletter
// list becomes a real asset rather than a maintenance tax.
//
// In the meantime, this block tells the truth, points readers to the essays
// already live on the site, and doesn't pretend to deliver an inbox subscription
// that won't actually arrive.
//
// When the time comes to switch this on, the previous integrated version is in
// git history at commit c7149066 (Newsletter.astro: rewrite as real Beehiiv-
// integrated capture form). The /api/subscribe route still exists and will
// resume working the moment env vars are set.

const { source = 'unknown', variant = 'default' } = Astro.props;
---

<section class={`newsletter newsletter--${variant}`} data-source={source}>
  <div class="newsletter__inner">
    <p class="newsletter__eyebrow">The Sunday Letter</p>
    <h2 class="newsletter__title">Coming soon. <em>The essays are already here.</em></h2>
    <p class="newsletter__lede">
      The Sunday Letter — one essay every Sunday morning, no filler — launches once the first thousand readers have arrived. Until then, the four founding manifesto essays and five sovereignty pillars are free on the site, no signup required. Read at your own pace.
    </p>
    <div class="newsletter__cta-row">
      <a href="/manifesto" class="newsletter__cta">Start with the manifesto <span class="newsletter__arrow">→</span></a>
    </div>
  </div>
</section>

<style>
  .newsletter__cta-row {
    margin-top: var(--space-6);
  }
  .newsletter__cta {
    font-family: var(--font-ui);
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ember);
    text-decoration: none;
    border-bottom: 1px solid var(--ember);
    padding-bottom: 2px;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: gap 0.25s var(--ease-out);
  }
  .newsletter__cta:hover {
    gap: var(--space-3);
  }
  .newsletter__arrow {
    display: inline-block;
    transition: transform 0.25s var(--ease-out);
  }
  .newsletter__cta:hover .newsletter__arrow {
    transform: translateX(4px);
  }
</style>
