---
// Newsletter capture component
// Submits to /api/subscribe (server-side proxy to Beehiiv)
// Provides success / error / loading states inline without page reload

const { source = 'unknown', variant = 'default' } = Astro.props;
---

<section class={`newsletter newsletter--${variant}`} data-source={source}>
  <div class="newsletter__inner">
    <p class="newsletter__eyebrow">The Sunday Letter</p>
    <h2 class="newsletter__title">One essay, every Sunday. <em>No filler. No pity.</em></h2>
    <p class="newsletter__lede">
      The unsparing weekly letter on what to build, in what order, and why. Free. Unsubscribe whenever.
    </p>
    <form class="newsletter__form js-newsletter-form">
      <label for="newsletter-email" class="screen-reader-only">Email address</label>
      <input
        id="newsletter-email"
        class="js-newsletter-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
      <!-- Honeypot field — invisible to humans, irresistible to bots -->
      <input
        type="text"
        name="website"
        class="newsletter__honeypot js-newsletter-honeypot"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <input type="hidden" name="source" value={source} class="js-newsletter-source" />
      <button type="submit" class="js-newsletter-submit">Subscribe</button>
    </form>
    <p class="newsletter__status js-newsletter-status" role="status" aria-live="polite"></p>
    <p class="newsletter__fineprint">No spam. No advertiser noise. Unsubscribe in one click.</p>
  </div>
</section>

<style>
  .newsletter__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .newsletter__status {
    font-family: var(--font-ui);
    font-size: var(--text-2xs);
    letter-spacing: 0.04em;
    min-height: 1.4em;
    margin: var(--space-3) 0 var(--space-2);
    color: var(--ash);
  }
  .newsletter__status[data-state="success"] {
    color: var(--ember);
    font-weight: 600;
  }
  .newsletter__status[data-state="error"] {
    color: #c0392b;
    font-weight: 500;
  }
  .js-newsletter-submit[data-loading="true"] {
    opacity: 0.65;
    cursor: progress;
  }
</style>

<script>
  // Wire up every newsletter form on the page.
  // Multiple instances are safe; each independently manages its own state.

  type Status = 'idle' | 'loading' | 'success' | 'error';

  const forms = document.querySelectorAll<HTMLFormElement>('.js-newsletter-form');

  forms.forEach((form) => {
    const emailInput = form.querySelector<HTMLInputElement>('.js-newsletter-email');
    const honeypot = form.querySelector<HTMLInputElement>('.js-newsletter-honeypot');
    const sourceInput = form.querySelector<HTMLInputElement>('.js-newsletter-source');
    const submitBtn = form.querySelector<HTMLButtonElement>('.js-newsletter-submit');
    const statusEl = form
      .closest('.newsletter')
      ?.querySelector<HTMLParagraphElement>('.js-newsletter-status');

    if (!emailInput || !submitBtn || !statusEl) return;

    const setStatus = (state: Status, message: string) => {
      statusEl.dataset.state = state === 'idle' ? '' : state;
      statusEl.textContent = message;
    };

    const setLoading = (loading: boolean) => {
      submitBtn.disabled = loading;
      submitBtn.dataset.loading = String(loading);
      submitBtn.textContent = loading ? 'Subscribing…' : 'Subscribe';
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = emailInput.value.trim();
      const trap = honeypot?.value.trim() ?? '';
      const source = sourceInput?.value ?? 'unknown';

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        setStatus('error', 'Please enter a valid email address.');
        return;
      }

      setLoading(true);
      setStatus('idle', '');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source, website: trap }),
        });

        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          message?: string;
        };

        if (res.ok && data.ok) {
          setStatus('success', 'You\u2019re in. Check your inbox for the welcome letter.');
          form.reset();
        } else {
          setStatus(
            'error',
            data.message ?? 'Something went wrong. Try again in a moment.',
          );
        }
      } catch (err) {
        setStatus('error', 'Network error. Try again in a moment.');
      } finally {
        setLoading(false);
      }
    });
  });
</script>
