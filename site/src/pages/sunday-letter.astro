---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Base
  title="The Sunday Letter — AfterChildren"
  description="One essay every Sunday morning. The unsparing weekly letter for parents whose children are grown — on what to build, in what order, and why. Free. Unsubscribe whenever."
>
  <!-- HERO -->
  <section class="page">
    <div class="sl-hero">
      <p class="sl-hero__eyebrow">The Sunday Letter</p>
      <h1 class="sl-hero__title">
        One essay.<br />
        <em>Every Sunday morning.</em>
      </h1>
      <p class="sl-hero__lede">
        The weekly letter for parents whose children are grown. One long essay. No filler. No advertiser noise. No pity. We send on Sunday mornings because that is when the second half of your life is loudest — the kids are not visiting, the week has not started, and the quiet is what people are most afraid of. We make it useful.
      </p>
    </div>
  </section>

  <!-- THE CAPTURE — top-of-page, no scroll required -->
  <section class="page">
    <Newsletter source="sunday-letter-page" variant="hero" />
  </section>

  <!-- WHAT YOU GET -->
  <section class="page">
    <div class="sl-whatyouget">
      <p class="sl-whatyouget__eyebrow">What arrives</p>
      <h2 class="sl-whatyouget__title">What the letter actually is.</h2>
      <div class="sl-whatyouget__grid">
        <div class="sl-feature">
          <h3 class="sl-feature__title">One essay, 1,500 to 3,500 words</h3>
          <p class="sl-feature__desc">Not a roundup. Not a digest. Not "here are 14 articles you should read." One piece, written deliberately, on a single question that matters in the second half of life. If we have nothing to say in a given week, we skip the week. We do not pad.</p>
        </div>
        <div class="sl-feature">
          <h3 class="sl-feature__title">No advertising in the body</h3>
          <p class="sl-feature__desc">There may eventually be a small sponsor line at the top or bottom — clearly labeled, never in the middle of the essay, never affecting the editorial. The essay you are reading is the essay we wrote. Nobody paid to be in it.</p>
        </div>
        <div class="sl-feature">
          <h3 class="sl-feature__title">No pity. No hedging.</h3>
          <p class="sl-feature__desc">The tone of most over-55 newsletters is condescending, hedging, or therapeutic. This one is not. We treat the reader as an adult who can handle direct information about money, body, mind, legal, and living decisions, and who is tired of being told what they want to hear.</p>
        </div>
        <div class="sl-feature">
          <h3 class="sl-feature__title">Unsubscribe in one click</h3>
          <p class="sl-feature__desc">Every email has a one-click unsubscribe link in the footer. No retention loop. No "we'll miss you" survey. If the letter is not for you, leave. We do not track you, sell your email, or use it for any purpose other than sending the letter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SAMPLE PIECES -->
  <section class="page">
    <div class="sl-samples">
      <p class="sl-samples__eyebrow">If you want a preview</p>
      <h2 class="sl-samples__title">The four manifesto essays already live.</h2>
      <p class="sl-samples__intro">
        The Sunday Letter is what arrives in your inbox. The manifesto essays below are the founding cluster — the four pieces that explain what this whole project is and is not. Read any of them and you will know whether the Sunday Letter is for you.
      </p>
      <div class="sl-samples__list">
        <a href="/manifesto" class="sl-sample">
          <span class="sl-sample__tag">Pinned</span>
          <h3 class="sl-sample__title">The AfterChildren Manifesto</h3>
          <p class="sl-sample__excerpt">Why this site exists, what it stands for, what it refuses to say.</p>
        </a>
        <a href="/manifestos/you-raised-them-now-build-yourself" class="sl-sample">
          <span class="sl-sample__tag">14 min read</span>
          <h3 class="sl-sample__title">You Raised Them. Now Build Yourself.</h3>
          <p class="sl-sample__excerpt">The five-sovereignty framework underneath the entire site.</p>
        </a>
        <a href="/manifestos/adult-children-not-retirement-plan" class="sl-sample">
          <span class="sl-sample__tag">15 min read</span>
          <h3 class="sl-sample__title">The Hardest Truth: Your Adult Children Are Not Your Retirement Plan</h3>
          <p class="sl-sample__excerpt">The quiet assumption baked into millions of retirement plans, and the math underneath why it fails.</p>
        </a>
        <a href="/manifestos/moving-in-with-kids-fails" class="sl-sample">
          <span class="sl-sample__tag">14 min read</span>
          <h3 class="sl-sample__title">Why Moving In With Your Kids Almost Always Fails</h3>
          <p class="sl-sample__excerpt">The 70% failure rate nobody warned you about, the three patterns where it works, and the alternative.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- SECOND CAPTURE — at the bottom for readers who scroll -->
  <section class="page">
    <div class="sl-secondcapture">
      <h2 class="sl-secondcapture__title">Ready?</h2>
      <p class="sl-secondcapture__lede">
        The next letter goes out this Sunday morning. Subscribe and you will be on the list before then. No confirmation hoops. One email. No spam. Unsubscribe whenever.
      </p>
      <Newsletter source="sunday-letter-page-bottom" variant="bottom" />
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .sl-hero {
    padding: var(--space-24) 0 var(--space-12);
    max-width: 44rem;
  }
  .sl-hero__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-2xs);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ember);
    margin-bottom: var(--space-6);
  }
  .sl-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--text-4xl));
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin-bottom: var(--space-6);
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .sl-hero__title em {
    font-style: italic;
    font-weight: 500;
    color: var(--ember);
  }
  .sl-hero__lede {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--ash);
  }

  /* WHAT YOU GET */
  .sl-whatyouget {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--stone);
  }
  .sl-whatyouget__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-2xs);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ember);
    margin-bottom: var(--space-4);
  }
  .sl-whatyouget__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-12);
    max-width: 32rem;
  }
  .sl-whatyouget__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--stone);
    border: 1px solid var(--stone);
  }
  @media (min-width: 768px) {
    .sl-whatyouget__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .sl-feature {
    background: var(--bone);
    padding: var(--space-10) var(--space-8);
  }
  .sl-feature__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .sl-feature__desc {
    font-size: var(--text-xs);
    line-height: 1.65;
    color: var(--ash);
  }

  /* SAMPLES */
  .sl-samples {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--stone);
  }
  .sl-samples__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-2xs);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ember);
    margin-bottom: var(--space-4);
  }
  .sl-samples__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-6);
    max-width: 32rem;
  }
  .sl-samples__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--ash);
    margin-bottom: var(--space-12);
    max-width: 36rem;
  }
  .sl-samples__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--stone);
  }
  .sl-sample {
    display: block;
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--stone);
    text-decoration: none;
    color: var(--ink);
    transition: padding 0.3s var(--ease-out);
  }
  .sl-sample:hover {
    padding-left: var(--space-4);
  }
  .sl-sample__tag {
    font-family: var(--font-ui);
    font-size: var(--text-3xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ember);
    display: inline-block;
    margin-bottom: var(--space-2);
  }
  .sl-sample__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }
  .sl-sample__excerpt {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--ash);
  }

  /* SECOND CAPTURE */
  .sl-secondcapture {
    padding: var(--space-16) 0 0;
    border-top: 1px solid var(--stone);
  }
  .sl-secondcapture__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-4);
  }
  .sl-secondcapture__lede {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--ash);
    margin-bottom: var(--space-12);
    max-width: 36rem;
  }
</style>
