<Article
  title="The Hardest Truth: Your Adult Children Are Not Your Retirement Plan"
  subtitle="The quiet assumption baked into millions of retirement plans — and the brutal math underneath why it fails."
  author="M. Holloway"
  published="2026-05-15"
